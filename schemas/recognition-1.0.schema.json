{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://accessibilizer.org/schemas/recognition-1.0.schema.json",
  "title": "Accessibilizer recognition candidates 1.0",
  "description": "Reproducible, source-linked recognition evidence for one page. Candidates and existing PDF text are non-authoritative inputs for later reconciliation and review, never final Semantic Layer content.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidates",
    "page",
    "pdf_text_evidence",
    "recognition",
    "rendering",
    "schema_version",
    "source_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "page": {"type": "integer", "minimum": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "rendering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dpi", "renderer", "renderer_version"],
      "properties": {
        "dpi": {"type": "integer", "minimum": 1},
        "renderer": {"type": "string", "minLength": 1},
        "renderer_version": {"type": "string", "minLength": 1}
      }
    },
    "recognition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "backend_version", "weights_version"],
      "properties": {
        "backend": {"type": "string", "minLength": 1},
        "backend_version": {"type": "string", "minLength": 1},
        "weights_version": {"type": "string", "minLength": 1}
      }
    },
    "candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate"}
    },
    "pdf_text_evidence": {"$ref": "#/$defs/pdf_text_evidence"}
  },
  "$defs": {
    "bbox": {
      "description": "[x0, y0, x1, y1] with a top-left origin and y increasing downward.",
      "type": "array",
      "prefixItems": [
        {"type": "number"},
        {"type": "number"},
        {"type": "number"},
        {"type": "number"}
      ],
      "items": false,
      "minItems": 4
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "bbox_pixels", "bbox_points", "crop", "id", "type"],
      "properties": {
        "id": {"type": "string", "pattern": "^page-[0-9]+-r[0-9]{4,}$"},
        "type": {
          "enum": [
            "text",
            "handwriting",
            "formula",
            "table",
            "figure",
            "document_structure"
          ]
        },
        "bbox_pixels": {"$ref": "#/$defs/bbox"},
        "bbox_points": {"$ref": "#/$defs/bbox"},
        "crop": {"type": "string", "minLength": 1},
        "backend": {"type": "string", "minLength": 1},
        "text": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "pdf_text_evidence": {
      "description": "Existing PDF text and geometry retained only as non-authoritative evidence.",
      "type": "object",
      "additionalProperties": false,
      "required": ["authoritative", "extractor", "extractor_version", "source", "words"],
      "properties": {
        "authoritative": {"const": false},
        "source": {"type": "string", "minLength": 1},
        "extractor": {"type": "string", "minLength": 1},
        "extractor_version": {"type": "string", "minLength": 1},
        "words": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bbox_points", "text"],
            "properties": {
              "text": {"type": "string"},
              "bbox_points": {"$ref": "#/$defs/bbox"}
            }
          }
        }
      }
    }
  }
}
