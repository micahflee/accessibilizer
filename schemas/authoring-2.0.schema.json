{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://accessibilizer.org/schemas/authoring-2.0.schema.json",
  "title": "Accessibilizer PDF authoring contract 2.0",
  "description": "The Python-to-Java authoring boundary for a whole document: the document title and language, and an ordered list of pages, each naming its source page and carrying that page's Semantic Layer in Logical Reading Order.",
  "type": "object",
  "additionalProperties": false,
  "required": ["language", "pages", "schema_version", "title"],
  "properties": {
    "language": {"type": "string", "minLength": 1},
    "schema_version": {"const": "2.0"},
    "title": {"type": "string", "minLength": 1},
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["semantic_layer", "source_page"],
        "properties": {
          "source_page": {"type": "integer", "minimum": 1},
          "semantic_layer": {
            "type": "array",
            "items": {
              "oneOf": [
                {"$ref": "#/$defs/heading"},
                {"$ref": "#/$defs/paragraph"},
                {"$ref": "#/$defs/formula"},
                {"$ref": "#/$defs/figure"},
                {"$ref": "#/$defs/link"},
                {"$ref": "#/$defs/table"}
              ]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "heading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "text", "type"],
      "properties": {
        "level": {"type": "integer", "minimum": 1, "maximum": 6},
        "text": {"type": "string", "minLength": 1},
        "type": {"const": "heading"}
      }
    },
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "type"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "type": {"const": "paragraph"}
      }
    },
    "formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalized_math", "spoken_math_alternative", "type"],
      "properties": {
        "normalized_math": {"type": "string", "minLength": 1},
        "spoken_math_alternative": {"type": "string", "minLength": 1},
        "type": {"const": "formula"}
      }
    },
    "figure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["complexity", "figure_alternative", "type"],
      "properties": {
        "complexity": {"enum": ["simple", "complex"]},
        "detailed_figure_description": {"type": "string", "minLength": 1},
        "figure_alternative": {"type": "string", "minLength": 1},
        "type": {"const": "figure"}
      },
      "if": {"properties": {"complexity": {"const": "complex"}}},
      "then": {"required": ["detailed_figure_description"]},
      "else": {"not": {"required": ["detailed_figure_description"]}}
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["href", "text", "type"],
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "type": {"const": "link"}
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "type"],
      "properties": {
        "caption": {"type": "string", "minLength": 1},
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cells"],
            "properties": {
              "cells": {
                "type": "array",
                "minItems": 1,
                "items": {"$ref": "#/$defs/table_cell"}
              }
            }
          }
        },
        "type": {"const": "table"}
      }
    },
    "table_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["col_span", "kind", "row_span", "scope", "text"],
      "properties": {
        "kind": {"enum": ["header", "data"]},
        "text": {"type": "string"},
        "scope": {"enum": ["col", "row", "both", "none"]},
        "row_span": {"type": "integer", "minimum": 1},
        "col_span": {"type": "integer", "minimum": 1}
      },
      "if": {"properties": {"kind": {"const": "data"}}},
      "then": {"properties": {"scope": {"const": "none"}}},
      "else": {"properties": {"scope": {"enum": ["col", "row", "both"]}}}
    }
  }
}
