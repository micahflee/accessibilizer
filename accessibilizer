#!/bin/sh
set -eu

# Suppress the Docker CLI's "What's next:" hints (e.g. the Docker Desktop
# "Debug this container error with Gordon" nudge), which the CLI prints after
# `docker run` regardless of outcome and which is not accessibilizer's output.
export DOCKER_CLI_HINTS=false

for argument in "$@"; do
    if [ "$argument" = "-h" ] || [ "$argument" = "--help" ]; then
        image=${ACCESSIBILIZER_IMAGE:-accessibilizer:0.1.0}
        exec docker run --rm "$image" python3 -m accessibilizer "$@"
    fi
done

json_flag=
resume_requested=
for argument in "$@"; do
    if [ "$argument" = "--json" ]; then json_flag=--json; fi
    if [ "$argument" = "--resume" ]; then resume_requested=--resume; fi
done

command=${1:-}
reported_this_run_total=0
reported_this_run_complete=true
reported_conversion_total=0
reported_conversion_complete=true
if [ -n "$resume_requested" ]; then
    # Until the persisted accounting has been loaded, a resumed conversion's
    # cumulative total is unknown rather than defensibly zero.
    reported_conversion_total=null
    reported_conversion_complete=false
fi

emit_reported_total() {
    label=$1
    total=$2
    complete=$3
    if [ "$total" = "null" ]; then
        echo "Reported tokens $label: unavailable (provider did not report sufficient usage)" >&2
    elif [ "$complete" = "false" ]; then
        echo "Reported tokens $label: at least $total" >&2
    else
        echo "Reported tokens $label: $total" >&2
    fi
}

emit_reported_token_usage() {
    emit_reported_total "this run" "$reported_this_run_total" "$reported_this_run_complete"
    emit_reported_total "conversion total" "$reported_conversion_total" "$reported_conversion_complete"
}

operational_failure() {
    if [ -n "$json_flag" ] && [ "$command" = "convert" ]; then
        printf '{"error":"%s","reported_token_usage":{"this_run":{"total_tokens":%s,"complete":%s},"conversion_total":{"total_tokens":%s,"complete":%s}},"status":"operational_failure"}\n' \
            "$1" "$reported_this_run_total" "$reported_this_run_complete" \
            "$reported_conversion_total" "$reported_conversion_complete"
    elif [ -n "$json_flag" ]; then
        printf '{"error":"%s","status":"operational_failure"}\n' "$1"
    else
        echo "accessibilizer: $1" >&2
        if [ "$command" = "convert" ]; then
            emit_reported_token_usage
        fi
    fi
    exit 1
}

container_runtime_failure() {
    reported_this_run_total=null
    reported_this_run_complete=false
    if [ -z "$resume_requested" ]; then
        reported_conversion_total=null
    fi
    reported_conversion_complete=false
    if [ -n "$json_flag" ]; then
        printf '{"error":"container runtime failed","reported_token_usage":{"this_run":{"total_tokens":%s,"complete":false},"conversion_total":{"total_tokens":%s,"complete":false}},"status":"operational_failure"}\n' \
            "$reported_this_run_total" "$reported_conversion_total"
    else
        echo "accessibilizer: container runtime failed" >&2
        emit_reported_token_usage
    fi
    exit 1
}

early_conversion_interruption() {
    trap - HUP INT TERM
    if [ -n "$json_flag" ]; then
        printf '{"reported_token_usage":{"this_run":{"total_tokens":%s,"complete":%s},"conversion_total":{"total_tokens":%s,"complete":%s}},"status":"interrupted"}\n' \
            "$reported_this_run_total" "$reported_this_run_complete" \
            "$reported_conversion_total" "$reported_conversion_complete"
    else
        echo "accessibilizer: interrupted" >&2
        emit_reported_token_usage
    fi
    exit 130
}

if [ "$command" = "report" ]; then
    shift
    bundle_path=
    source_path=
    record_path=
    output_path=
    replace_flag=
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --bundle) [ "$#" -ge 2 ] || operational_failure "--bundle requires a value"; bundle_path=$2; shift 2 ;;
            --source) [ "$#" -ge 2 ] || operational_failure "--source requires a value"; source_path=$2; shift 2 ;;
            --record) [ "$#" -ge 2 ] || operational_failure "--record requires a value"; record_path=$2; shift 2 ;;
            --output) [ "$#" -ge 2 ] || operational_failure "--output requires a value"; output_path=$2; shift 2 ;;
            --replace) replace_flag=--replace; shift ;;
            --json) json_flag=--json; shift ;;
            *) operational_failure "unknown argument" ;;
        esac
    done

    image=${ACCESSIBILIZER_IMAGE:-accessibilizer:0.1.0}
    if [ -n "$bundle_path" ]; then
        if [ -n "$source_path$output_path$record_path" ]; then
            operational_failure "--bundle cannot be combined with --source, --record, or --output"
        fi
        if [ ! -d "$bundle_path" ]; then
            operational_failure "bundle must be an existing Conversion Bundle directory"
        fi
        case "$bundle_path" in
            /*) host_output_path=$bundle_path ;;
            *) host_output_path="$(pwd)/$bundle_path" ;;
        esac
        bundle_parent=$(cd "$(dirname "$bundle_path")" && pwd -P) || \
            operational_failure "could not resolve the bundle directory"
        bundle_name=$(basename "$bundle_path")
        set -- --rm --network none \
            --user "$(id -u):$(id -g)" \
            --volume "$bundle_parent:/work/output" \
            --env "ACCESSIBILIZER_HOST_BUNDLE=$host_output_path" \
            "$image" python3 -m accessibilizer report \
            --bundle "/work/output/$bundle_name"
    else
        if [ -z "$source_path" ] || [ -z "$record_path" ] || [ -z "$output_path" ]; then
            operational_failure "standalone report requires --source, --record, and --output"
        fi
        if [ ! -f "$source_path" ] || [ ! -f "$record_path" ]; then
            operational_failure "--source and --record must be files"
        fi
        source_directory=$(cd "$(dirname "$source_path")" && pwd -P) || \
            operational_failure "could not resolve the Source PDF directory"
        record_directory=$(cd "$(dirname "$record_path")" && pwd -P) || \
            operational_failure "could not resolve the Review Record directory"
        source_path="$source_directory/$(basename "$source_path")"
        record_path="$record_directory/$(basename "$record_path")"
        output_parent=$(dirname "$output_path")
        output_name=$(basename "$output_path")
        case "$output_path" in
            /*) host_output_path=$output_path ;;
            *) host_output_path="$(pwd)/$output_path" ;;
        esac
        mkdir -p "$output_parent" || operational_failure "could not create the report parent directory"
        output_parent=$(cd "$output_parent" && pwd -P) || \
            operational_failure "could not resolve the report parent directory"
        set -- --rm --network none \
            --user "$(id -u):$(id -g)" \
            --volume "$source_path:/work/source.pdf:ro" \
            --volume "$record_path:/work/review-record.yaml:ro" \
            --volume "$output_parent:/work/output" \
            --env "ACCESSIBILIZER_HOST_BUNDLE=$host_output_path" \
            "$image" python3 -m accessibilizer report \
            --source /work/source.pdf \
            --record /work/review-record.yaml \
            --output "/work/output/$output_name"
        if [ -n "$replace_flag" ]; then set -- "$@" --replace; fi
    fi
    if [ -n "$json_flag" ]; then set -- "$@" --json; fi
    if docker run "$@"; then
        result=0
    else
        result=$?
    fi
    if [ "$result" -ne 0 ] && [ "$result" -ne 1 ] && [ "$result" -ne 2 ] && [ -n "$json_flag" ]; then
        printf '{"error":"container runtime failed","status":"operational_failure"}\n'
    fi
    exit "$result"
fi

if [ "$command" = "finalize" ] || [ "$command" = "validate" ] || [ "$command" = "review" ]; then
    shift
    bundle_path=
    reviewer=
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --bundle) [ "$#" -ge 2 ] || operational_failure "--bundle requires a value"; bundle_path=$2; shift 2 ;;
            --reviewer) [ "$#" -ge 2 ] || operational_failure "--reviewer requires a value"; reviewer=$2; shift 2 ;;
            --json) json_flag=--json; shift ;;
            *) operational_failure "unknown argument" ;;
        esac
    done
    if [ -z "$bundle_path" ]; then
        operational_failure "--bundle is required"
    fi
    if [ ! -d "$bundle_path" ]; then
        operational_failure "bundle must be an existing Conversion Bundle directory"
    fi
    if { [ "$command" = "validate" ] || [ "$command" = "report" ]; } && [ -n "$reviewer" ]; then
        operational_failure "validate does not accept --reviewer"
    fi

    bundle_parent=$(cd "$(dirname "$bundle_path")" && pwd -P) || \
        operational_failure "could not resolve the bundle directory"
    bundle_name=$(basename "$bundle_path")
    host_bundle_path="$bundle_parent/$bundle_name"

    image=${ACCESSIBILIZER_IMAGE:-accessibilizer:0.1.0}
    user_config_path=
    if [ -n "${XDG_CONFIG_HOME:-}" ]; then
        user_config_path=$XDG_CONFIG_HOME/accessibilizer/config.toml
    elif [ -n "${HOME:-}" ]; then
        user_config_path=$HOME/.config/accessibilizer/config.toml
    fi
    project_config_path=$(pwd)/accessibilizer.toml

    cid_directory=$(mktemp -d "$bundle_parent/.${bundle_name}.container.XXXXXX") || \
        operational_failure "could not prepare the container runtime"
    cidfile="$cid_directory/id"
    stop_bundle_container() {
        if [ -f "$cidfile" ]; then
            container_id=
            IFS= read -r container_id < "$cidfile" || true
            if [ -n "$container_id" ]; then
                docker stop --time 1 "$container_id" >/dev/null 2>&1 || true
            fi
        fi
        rm -f "$cidfile"
        rmdir "$cid_directory" 2>/dev/null || true
    }
    trap 'stop_bundle_container; exit 143' HUP INT TERM

    # finalize, validate, and review make no provider calls, so the container is
    # denied network access to enforce that guarantee at the runtime boundary.
    set -- --rm --network none \
        --cidfile "$cidfile" \
        --user "$(id -u):$(id -g)" \
        --volume "$bundle_parent:/work/output" \
        --env "ACCESSIBILIZER_HOST_BUNDLE=$host_bundle_path"
    if [ -n "$user_config_path" ] && [ -f "$user_config_path" ]; then
        set -- "$@" --volume "$user_config_path:/work/user-config.toml:ro" --env ACCESSIBILIZER_USER_CONFIG=/work/user-config.toml
    fi
    if [ -f "$project_config_path" ]; then
        set -- "$@" --volume "$project_config_path:/work/project-config.toml:ro" --env ACCESSIBILIZER_PROJECT_CONFIG=/work/project-config.toml
    fi
    if [ -t 0 ]; then set -- --interactive "$@"; fi
    if [ -t 1 ]; then set -- --tty "$@"; fi
    set -- "$@" "$image" \
        python3 -m accessibilizer "$command" --bundle "/work/output/$bundle_name"
    if [ -n "$reviewer" ]; then set -- "$@" --reviewer "$reviewer"; fi
    if [ -n "$json_flag" ]; then set -- "$@" --json; fi

    if docker run "$@"; then
        result=0
    else
        result=$?
    fi
    trap - HUP INT TERM
    rm -f "$cidfile"
    rmdir "$cid_directory" 2>/dev/null || true
    if [ "$result" -ne 0 ] && [ "$result" -ne 1 ] && [ "$result" -ne 2 ] && [ -n "$json_flag" ]; then
        printf '{"error":"container runtime failed","status":"operational_failure"}\n'
    fi
    # Only finalize republishes the bundle; keep the immutable source copy read-only.
    if [ "$command" = "finalize" ] && { [ "$result" -eq 0 ] || [ "$result" -eq 2 ]; }; then
        chmod 400 "$bundle_path/source.pdf" 2>/dev/null || true
    fi
    exit "$result"
fi

if [ "$command" != "convert" ]; then
    operational_failure "usage: accessibilizer {convert,report,review,validate,finalize} ... (see --help)"
fi
shift
trap 'early_conversion_interruption' HUP INT TERM

source_path=${1:-}
if [ -z "$source_path" ]; then
    operational_failure "SOURCE is required"
fi
shift

page=
bundle_path=
replace_flag=
provider_base_url=
provider_model=
provider_api_key_env=
provider_data_location=
allow_remote_flag=
max_requests=
provider_max_retries=
provider_retry_base_seconds=
provider_retry_max_seconds=
resume_flag=
verbose_flag=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --page) [ "$#" -ge 2 ] || operational_failure "--page requires a value"; page=$2; shift 2 ;;
        --bundle) [ "$#" -ge 2 ] || operational_failure "--bundle requires a value"; bundle_path=$2; shift 2 ;;
        --provider-base-url) [ "$#" -ge 2 ] || operational_failure "--provider-base-url requires a value"; provider_base_url=$2; shift 2 ;;
        --provider-model) [ "$#" -ge 2 ] || operational_failure "--provider-model requires a value"; provider_model=$2; shift 2 ;;
        --provider-api-key-env) [ "$#" -ge 2 ] || operational_failure "--provider-api-key-env requires a value"; provider_api_key_env=$2; shift 2 ;;
        --provider-data-location) [ "$#" -ge 2 ] || operational_failure "--provider-data-location requires a value"; provider_data_location=$2; shift 2 ;;
        --max-requests) [ "$#" -ge 2 ] || operational_failure "--max-requests requires a value"; max_requests=$2; shift 2 ;;
        --provider-max-retries) [ "$#" -ge 2 ] || operational_failure "--provider-max-retries requires a value"; provider_max_retries=$2; shift 2 ;;
        --provider-retry-base-seconds) [ "$#" -ge 2 ] || operational_failure "--provider-retry-base-seconds requires a value"; provider_retry_base_seconds=$2; shift 2 ;;
        --provider-retry-max-seconds) [ "$#" -ge 2 ] || operational_failure "--provider-retry-max-seconds requires a value"; provider_retry_max_seconds=$2; shift 2 ;;
        --allow-remote) allow_remote_flag=--allow-remote; shift ;;
        --resume) resume_flag=--resume; shift ;;
        --replace) replace_flag=--replace; shift ;;
        --json) json_flag=--json; shift ;;
        --verbose) verbose_flag=--verbose; shift ;;
        *) operational_failure "unknown argument" ;;
    esac
done

if [ -z "$bundle_path" ]; then
    operational_failure "--bundle is required"
fi

absolute_file() {
    directory=$(dirname "$1")
    filename=$(basename "$1")
    printf '%s/%s\n' "$(cd "$directory" && pwd -P)" "$filename"
}

bundle_parent=$(dirname "$bundle_path")
bundle_name=$(basename "$bundle_path")
mkdir -p "$bundle_parent" || operational_failure "could not create the bundle parent directory"
case "$bundle_path" in
    /*) host_bundle_path=$bundle_path ;;
    *) host_bundle_path="$(pwd)/$bundle_path" ;;
esac
bundle_parent=$(cd "$bundle_parent" && pwd -P)
bundle_path="$bundle_parent/$bundle_name"

image=${ACCESSIBILIZER_IMAGE:-accessibilizer:0.1.0}
if [ -n "$resume_flag" ]; then
    set -- --rm \
        --volume "$bundle_parent:/work/output" \
        "$image" python3 -m accessibilizer reported-token-usage \
        --bundle "/work/output/$bundle_name"
    if persisted_usage=$(docker run "$@"); then
        set -- $persisted_usage
        if [ "$#" -ne 4 ]; then
            operational_failure "incomplete conversion has invalid request usage"
        fi
        reported_this_run_total=$1
        reported_this_run_complete=$2
        reported_conversion_total=$3
        reported_conversion_complete=$4
    else
        operational_failure "incomplete conversion has invalid request usage"
    fi
fi
if [ ! -f "$source_path" ]; then
    operational_failure "source must be a file"
fi
source_path=$(absolute_file "$source_path")

user_config_path=
if [ -n "${XDG_CONFIG_HOME:-}" ]; then
    user_config_path=$XDG_CONFIG_HOME/accessibilizer/config.toml
elif [ -n "${HOME:-}" ]; then
    user_config_path=$HOME/.config/accessibilizer/config.toml
fi
project_config_path=$(pwd)/accessibilizer.toml

set -- --rm
if [ -n "$user_config_path" ] && [ -f "$user_config_path" ]; then
    set -- "$@" --volume "$user_config_path:/work/user-config.toml:ro" --env ACCESSIBILIZER_USER_CONFIG=/work/user-config.toml
fi
if [ -f "$project_config_path" ]; then
    set -- "$@" --volume "$project_config_path:/work/project-config.toml:ro" --env ACCESSIBILIZER_PROJECT_CONFIG=/work/project-config.toml
fi
set -- "$@" "$image" python3 -m accessibilizer provider-key-env
if [ -n "$provider_base_url" ]; then set -- "$@" --provider-base-url "$provider_base_url"; fi
if [ -n "$provider_model" ]; then set -- "$@" --provider-model "$provider_model"; fi
if [ -n "$provider_api_key_env" ]; then set -- "$@" --provider-api-key-env "$provider_api_key_env"; fi
if [ -n "$provider_data_location" ]; then set -- "$@" --provider-data-location "$provider_data_location"; fi
if api_key_env=$(docker run "$@"); then
    :
else
    operational_failure "provider configuration could not be resolved"
fi

cid_directory=$(mktemp -d "$bundle_parent/.${bundle_name}.container.XXXXXX") || \
    operational_failure "could not prepare the container runtime"
cidfile="$cid_directory/id"
container_stdout=
stop_conversion_container() {
    # Give the container time to record the interruption, print the resume
    # command, and exit 130 gracefully before it is force-stopped. docker run's
    # signal proxy also forwards the interrupt, so this is a fallback.
    if [ -f "$cidfile" ]; then
        container_id=
        IFS= read -r container_id < "$cidfile" || true
        if [ -n "$container_id" ]; then
            docker stop --time 10 "$container_id" >/dev/null 2>&1 || true
        fi
    fi
    rm -f "$cidfile"
    rmdir "$cid_directory" 2>/dev/null || true
}
# Stop the container on an interrupt but do not exit here: let the foreground
# `docker run` relay the container's own interruption output and exit status
# (130) so the resume command reaches the user.
trap 'stop_conversion_container' HUP INT TERM

set -- --rm \
    --cidfile "$cidfile" \
    --user "$(id -u):$(id -g)" \
    --add-host "host.docker.internal:host-gateway" \
    --volume "$source_path:/work/source.pdf:ro" \
    --volume "$bundle_parent:/work/output" \
    --env "ACCESSIBILIZER_HOST_BUNDLE=$host_bundle_path" \
    --env "ACCESSIBILIZER_HOST_SOURCE=$source_path"
if [ -n "${ACCESSIBILIZER_RECOGNITION_BACKEND:-}" ]; then
    set -- "$@" --env "ACCESSIBILIZER_RECOGNITION_BACKEND=$ACCESSIBILIZER_RECOGNITION_BACKEND"
fi
if [ -n "${ACCESSIBILIZER_PADDLE_WEIGHTS_VERSION:-}" ]; then
    set -- "$@" --env "ACCESSIBILIZER_PADDLE_WEIGHTS_VERSION=$ACCESSIBILIZER_PADDLE_WEIGHTS_VERSION"
fi
if [ -n "$user_config_path" ] && [ -f "$user_config_path" ]; then
    set -- "$@" --volume "$user_config_path:/work/user-config.toml:ro" --env ACCESSIBILIZER_USER_CONFIG=/work/user-config.toml
fi
if [ -f "$project_config_path" ]; then
    set -- "$@" --volume "$project_config_path:/work/project-config.toml:ro" --env ACCESSIBILIZER_PROJECT_CONFIG=/work/project-config.toml
fi
if [ -n "$api_key_env" ]; then set -- "$@" --env "$api_key_env"; fi
if [ -t 0 ]; then set -- --interactive "$@"; fi
if [ -t 1 ]; then set -- --tty "$@"; fi
set -- "$@" "$image" \
    python3 -m accessibilizer convert /work/source.pdf \
    --bundle "/work/output/$bundle_name"
if [ -n "$page" ]; then set -- "$@" --page "$page"; fi
if [ -n "$provider_base_url" ]; then set -- "$@" --provider-base-url "$provider_base_url"; fi
if [ -n "$provider_model" ]; then set -- "$@" --provider-model "$provider_model"; fi
if [ -n "$provider_api_key_env" ]; then set -- "$@" --provider-api-key-env "$provider_api_key_env"; fi
if [ -n "$provider_data_location" ]; then set -- "$@" --provider-data-location "$provider_data_location"; fi
if [ -n "$allow_remote_flag" ]; then set -- "$@" --allow-remote; fi
if [ -n "$max_requests" ]; then set -- "$@" --max-requests "$max_requests"; fi
if [ -n "$provider_max_retries" ]; then set -- "$@" --provider-max-retries "$provider_max_retries"; fi
if [ -n "$provider_retry_base_seconds" ]; then set -- "$@" --provider-retry-base-seconds "$provider_retry_base_seconds"; fi
if [ -n "$provider_retry_max_seconds" ]; then set -- "$@" --provider-retry-max-seconds "$provider_retry_max_seconds"; fi
if [ -n "$json_flag" ]; then set -- "$@" --json; fi
if [ -n "$verbose_flag" ]; then set -- "$@" --verbose; fi
if [ -n "$replace_flag" ]; then set -- "$@" --replace; fi
if [ -n "$resume_flag" ]; then set -- "$@" --resume; fi

if [ -n "$json_flag" ]; then
    container_stdout=$(mktemp "$bundle_parent/.${bundle_name}.result.XXXXXX") || \
        operational_failure "could not prepare the container runtime"
    if docker run "$@" >"$container_stdout"; then
        result=0
    else
        result=$?
    fi
else
    if docker run "$@"; then
        result=0
    else
        result=$?
    fi
fi
trap - HUP INT TERM
rm -f "$cidfile"
rmdir "$cid_directory" 2>/dev/null || true
# 130 is an intentional interruption whose machine-readable result the container
# already produced; do not mask it as a container-runtime failure.
if [ "$result" -ne 0 ] && [ "$result" -ne 1 ] && [ "$result" -ne 2 ] \
    && [ "$result" -ne 130 ]; then
    if [ -n "$container_stdout" ]; then
        rm -f "$container_stdout"
        container_stdout=
    fi
    container_runtime_failure
fi
if [ -n "$container_stdout" ]; then
    cat "$container_stdout"
    rm -f "$container_stdout"
fi
if [ "$result" -eq 0 ] || [ "$result" -eq 2 ]; then
    chmod 400 "$bundle_path/source.pdf"
fi
exit "$result"
